      <aliases enabled='yes' />
      <column caption='Segment Order' datatype='integer' name='[Calculation_2923279563956224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [segment]&#10;  WHEN &quot;Champions&quot; THEN 1&#10;  WHEN &quot;Loyal Customers&quot; THEN 2&#10;  WHEN &quot;Cant Lose Them&quot; THEN 3&#10;  WHEN &quot;Potential Loyalists&quot; THEN 4&#10;  WHEN &quot;Promising&quot; THEN 5&#10;  WHEN &quot;Needs Attention&quot; THEN 6&#10;  WHEN &quot;At Risk&quot; THEN 7&#10;  WHEN &quot;Lost&quot; THEN 8&#10;  WHEN &quot;Hibernating&quot; THEN 9&#10;  WHEN &quot;About To Sleep&quot; THEN 10&#10;  WHEN &quot;New Customers&quot; THEN 11&#10;END' />
      </column>
      <column caption='Risk Flag' datatype='string' name='[Calculation_2923279564050433]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [segment] = &quot;At Risk&quot; OR [segment] = &quot;Cant Lose Them&quot; OR [segment] = &quot;Hibernating&quot;&#10;THEN &quot;At Risk&quot; ELSE &quot;Not At Risk&quot; END' />
      </column>
      <column caption='champions revenue share' datatype='real' name='[Calculation_2923279651340292]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [segment] = &quot;Champions&quot; THEN [monetary] END) / SUM([monetary])' />
      </column>
